{
  "name": "@taias/sdk",
  "version": "0.11.1",
  "type": "module",
  "description": "Taias - Give your MCP server an opinion, guide your users to achieve outcomes",
  "license": "Apache-2.0",
  "author": "Taias",
  "homepage": "https://taias.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taias-xyz/taias-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/taias-xyz/taias-sdk/issues"
  },
  "keywords": [
    "mcp",
    "ai",
    "agent",
    "flow",
    "taias"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "release": "bash scripts/publish.sh"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
